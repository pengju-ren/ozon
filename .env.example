# ============================================================
# 1688 API 配置 (OneBound / Open Claw)
# 注册: https://open-claw.cn 获取免费 500次/天
# ============================================================
ONEBOUND_API_KEY=your_api_key_here
ONEBOUND_API_SECRET=your_api_secret_here

# ============================================================
# 百度翻译 API（国内推荐）
# 申请步骤:
#   1. 访问 https://fanyi-api.baidu.com/
#   2. 注册/登录百度账号
#   3. 开通"通用翻译API"，选择"标准版"（免费 200万字符/月）
#   4. 在 https://fanyi-api.baidu.com/manage/developer 获取 APP ID 和密钥
# ============================================================
BAIDU_APPID=
BAIDU_SECRET_KEY=

# ============================================================
# 可选配置
# ============================================================
# Google 翻译（默认为 false，如果网络能访问 Google 可设为 true）
GOOGLE_TRANSLATE_ENABLED=false

# CSV 预翻译文件路径（可选，手动翻译常用词后复用）
CSV_TRANSLATION_FILE=

# 汇率配置（卢布→人民币，默认 1 RUB ≈ 0.078 CNY）
RUB_TO_CNY=0.078
